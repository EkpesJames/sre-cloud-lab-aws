{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "Cloud Lab — SRE Overview: SLO status, error budget, latency, traffic",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "id": 1,
      "type": "stat",
      "title": "Availability (5m)",
      "description": "Current success rate. SLO target: 99%",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.95 },
              { "color": "green", "value": 0.99 }
            ]
          },
          "mappings": []
        }
      },
      "targets": [
        {
          "expr": "slo:success_rate_5m",
          "legendFormat": "Availability",
          "refId": "A"
        }
      ]
    },

    {
      "id": 2,
      "type": "stat",
      "title": "Error Budget Remaining",
      "description": "Remaining error budget. 1.0 = full, 0.0 = exhausted",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.25 },
              { "color": "green", "value": 0.50 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "slo:error_budget_remaining",
          "legendFormat": "Budget Remaining",
          "refId": "A"
        }
      ]
    },

    {
      "id": 3,
      "type": "stat",
      "title": "Burn Rate (1h)",
      "description": "Error budget burn rate. >14.4 = budget exhausted in 2h",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 6 },
              { "color": "red", "value": 14.4 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "slo:error_budget_burn_rate_1h",
          "legendFormat": "Burn Rate",
          "refId": "A"
        }
      ]
    },

    {
      "id": 4,
      "type": "stat",
      "title": "p95 Latency",
      "description": "95th percentile request latency. SLO target: <500ms",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.5 },
              { "color": "red", "value": 1.0 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "slo:latency_p95_5m",
          "legendFormat": "p95 Latency",
          "refId": "A"
        }
      ]
    },

    {
      "id": 5,
      "type": "stat",
      "title": "Request Rate",
      "description": "Requests per second across all status codes",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        }
      },
      "targets": [
        {
          "expr": "slo:request_rate_5m",
          "legendFormat": "req/s",
          "refId": "A"
        }
      ]
    },

    {
      "id": 6,
      "type": "timeseries",
      "title": "Request Rate — Success vs Error",
      "description": "Per-second request rate broken down by status",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Errors" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Success" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] }
        ]
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "expr": "rate(http_requests_total{status=\"success\"}[5m])", "legendFormat": "Success", "refId": "A" },
        { "expr": "rate(http_requests_total{status=\"error\"}[5m])", "legendFormat": "Errors", "refId": "B" }
      ]
    },

    {
      "id": 7,
      "type": "timeseries",
      "title": "Latency Percentiles",
      "description": "p50 / p95 / p99 request latency over time",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2 } }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "expr": "slo:latency_p50_5m", "legendFormat": "p50", "refId": "A" },
        { "expr": "slo:latency_p95_5m", "legendFormat": "p95 (SLO)", "refId": "B" },
        { "expr": "slo:latency_p99_5m", "legendFormat": "p99", "refId": "C" }
      ]
    },

    {
      "id": 8,
      "type": "timeseries",
      "title": "Error Budget Remaining Over Time",
      "description": "Tracks error budget consumption. Drops toward 0 during incidents.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": { "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.25 },
              { "color": "green", "value": 0.5 }
            ]
          }
        }
      },
      "options": { "tooltip": { "mode": "single" } },
      "targets": [
        { "expr": "slo:error_budget_remaining", "legendFormat": "Budget Remaining", "refId": "A" }
      ]
    },

    {
      "id": 9,
      "type": "timeseries",
      "title": "Error Budget Burn Rate",
      "description": "1h and 6h burn rates. Threshold lines at 14.4x (critical) and 6x (warning).",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "slo:error_budget_burn_rate_1h", "legendFormat": "Burn Rate (1h)", "refId": "A" },
        { "expr": "slo:error_budget_burn_rate_6h", "legendFormat": "Burn Rate (6h)", "refId": "B" },
        { "expr": "vector(14.4)", "legendFormat": "Critical threshold", "refId": "C" },
        { "expr": "vector(6)", "legendFormat": "Warning threshold", "refId": "D" }
      ]
    }

  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["sre", "cloud-lab", "slo"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Cloud Lab — SRE Overview",
  "uid": "cloud-lab-sre-overview",
  "version": 1
}
