# ─────────────────────────────────────────────────────────────────────────────
# .env.example — template for local development credentials
#
# SETUP INSTRUCTIONS:
#   1. Copy this file: cp .env.example .env
#   2. Fill in real values in .env
#   3. Never commit .env to git (it's in .gitignore)
#   4. Run: bash secrets-audit.sh to verify nothing is exposed
#
# WHERE EACH SECRET IS USED:
#   Local Docker mode  → lab script reads .env directly
#   Kubernetes mode    → k8s-apply.sh creates K8s Secret from .env
#   CI/CD pipeline     → GitHub Actions Secrets (set separately)
#   Alertmanager       → week2-deploy.sh runs envsubst against .env
# ─────────────────────────────────────────────────────────────────────────────

# ── Slack ─────────────────────────────────────────────────────────────────────
# Get from: https://api.slack.com/apps → your app → Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks\.slack\.com/services/[A-Z0-9]{9}/[A-Z0-9]{11}/[A-Za-z0-9]{24}
SLACK_CHANNEL=#general

# ── Email (Yahoo SMTP) ────────────────────────────────────────────────────────
# Generate app password at: https://myaccount.yahoo.com → Security → App passwords
SMTP_HOST=smtp.mail.yahoo.com
SMTP_PORT=587
SMTP_FROM=your-email@yahoo.co.uk
SMTP_USERNAME=your-email@yahoo.co.uk
SMTP_PASSWORD=your-16-char-app-password-here
ALERT_EMAIL_TO=your-email@yahoo.co.uk

# ── GitHub Container Registry ─────────────────────────────────────────────────
# Generate PAT at: https://github.com/settings/tokens
# Required scopes: repo, write:packages, read:packages
GHCR_USERNAME=your-github-username
GHCR_PAT=ghp_your_personal_access_token_here

# ── App behaviour ─────────────────────────────────────────────────────────────
APP_ERROR_RATE=0.30
APP_LATENCY_SECONDS=0.2

# ── Circuit breaker ───────────────────────────────────────────────────────────
CIRCUIT_THRESHOLD=0.50
CIRCUIT_TIMEOUT=30

# ── Jaeger tracing ────────────────────────────────────────────────────────────
JAEGER_ENDPOINT=http://jaeger.monitoring.svc.cluster.local:4317

# ── SLO targets ───────────────────────────────────────────────────────────────
SLO_AVAILABILITY_TARGET=0.99
SLO_LATENCY_P95_TARGET_SECONDS=0.5

# ─────────────────────────────────────────────────────────────────────────────
# GITHUB ACTIONS SECRETS (set these separately in GitHub repo settings)
# https://github.com/YOUR_USERNAME/sre-cloud-lab/settings/secrets/actions
#
#   PAT_TOKEN          → your GitHub PAT (same as GHCR_PAT above)
#   SLACK_WEBHOOK_URL  → same as SLACK_WEBHOOK_URL above
# ─────────────────────────────────────────────────────────────────────────────

# ─────────────────────────────────────────────────────────────────────────────
# K3S REGISTRY CREDENTIALS (set once on WSL2 machine)
# sudo tee /etc/rancher/k3s/registries.yaml << EOF
# configs:
#   "ghcr.io":
#     auth:
#       username: YOUR_GITHUB_USERNAME
#       password: YOUR_PAT_TOKEN
# EOF
# sudo systemctl restart k3s
# ─────────────────────────────────────────────────────────────────────────────
